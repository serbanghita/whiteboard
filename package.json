{
  "name": "@serbanghita-gamedev/demo-whiteboard",
  "version": "1.0.0",
  "description": "Demo of a simple whiteboard",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --sourcemap --loader:.png=dataurl --outfile=dist/demo.js",
    "dev": "esbuild src/index.ts --bundle --sourcemap --watch --loader:.png=dataurl --outfile=dist/demo.js --servedir=dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "Serban Ghita <serbanghita@gmail.com> (https://ghita.org)",
  "license": "All code is MIT, the assets are copywritten.",
  "devDependencies": {
    "@eslint/js": "^9.4.0",
    "@nx/esbuild": "^19.1.1",
    "@nx/eslint": "^19.1.1",
    "@serbanghita-gamedev/ecs": "file:../gamedev-published-repos/ecs",
    "@serbanghita-gamedev/quadtree": "file:../gamedev-published-repos/quadtree",
    "@types/eslint__js": "^8.42.3",
    "@vitest/coverage-istanbul": "^2.1.1",
    "esbuild": "^0.19.2",
    "eslint": "^9.4.0",
    "jest": "^29.4.1",
    "jsdom": "^27.4.0",
    "nx": "19.1.1",
    "prettier": "3.3.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.10.0",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.1.1"
  }
}
